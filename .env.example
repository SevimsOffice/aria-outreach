# ============================================================
# ARIA — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to GitHub — it contains your API keys.
# ============================================================

# --- Claude AI (console.anthropic.com) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Sheets ---
# Paste the FULL JSON content of your service account key file (as one line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# The Google Sheet ID from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# --- Instantly.ai (app.instantly.ai → Settings → API) ---
INSTANTLY_API_KEY=inst_...
INSTANTLY_CAMPAIGN_ID=campaign-uuid-here

# --- Email Enrichment ---
# Apollo.io (app.apollo.io → Settings → Integrations → API Keys)
APOLLO_API_KEY=your_apollo_key_here
# Hunter.io (hunter.io → API → Keys)  — optional, free tier 25/month
HUNTER_API_KEY=your_hunter_key_here

# --- Telegram ---
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHI...
# Your personal chat ID — send any message to your bot then visit:
# https://api.telegram.org/bot{YOUR_TOKEN}/getUpdates → look for "chat":{"id":...}
TELEGRAM_CHAT_ID=987654321

# --- Pipeline Config ---
DAILY_SEND_LIMIT=50
